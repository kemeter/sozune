# Build artifacts (match nested target/ and node_modules/ in sub-projects too,
# e.g. bench/*/target, tests/e2e/plugins/*/target — otherwise they bloat the
# build context by hundreds of MB on every `docker build`).
**/target/
**/node_modules/
dashboard/build/
dashboard/.svelte-kit/

# VCS / tooling
.git/
.gitignore
.github/

# Project-local junk that doesn't belong in the image
bin/
certs/
issues/
.claude/
.prd/
config_dev.yaml
entrypoints.yaml
middleware.md
ROADMAP.md

# E2E test infrastructure and perf bench (not needed for the binary)
tests/e2e/
bench/

# Logs / editor / OS
*.log
*.swp
.DS_Store
